{
  "name": "fabricpulse",
  "displayName": "FabricPulse",
  "description": "Real-time Microsoft Fabric pipeline monitor for VS Code",
  "version": "1.1.6",
  "publisher": "evolve-data",
  "license": "MIT",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Y0hannH/FabricPulse"
  },
  "homepage": "https://github.com/Y0hannH/FabricPulse#readme",
  "bugs": {
    "url": "https://github.com/Y0hannH/FabricPulse/issues"
  },
  "galleryBanner": {
    "color": "#16213e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "fabric",
    "microsoft",
    "pipeline",
    "monitor",
    "azure"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fabricpulse-sidebar",
          "title": "FabricPulse",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "fabricpulse-sidebar": [
        {
          "id": "fabricpulse.launchView",
          "name": "FabricPulse",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "fabricpulse.launchView",
        "contents": "⚡ Monitor your Microsoft Fabric data pipelines in real time.\n\n[$(pulse) Open Dashboard](command:fabricPulse.openDashboard)\n\n[$(add) Add Tenant](command:fabricPulse.addTenant)\n\n[$(trash) Clear History](command:fabricPulse.clearHistory)"
      }
    ],
    "commands": [
      {
        "command": "fabricPulse.openDashboard",
        "title": "FabricPulse: Open Dashboard",
        "icon": "$(pulse)"
      },
      {
        "command": "fabricPulse.addTenant",
        "title": "FabricPulse: Add Tenant"
      },
      {
        "command": "fabricPulse.exportHistory",
        "title": "FabricPulse: Export History (CSV)"
      },
      {
        "command": "fabricPulse.clearHistory",
        "title": "FabricPulse: Clear Local History"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "fabricPulse.openDashboard"
        },
        {
          "command": "fabricPulse.addTenant"
        },
        {
          "command": "fabricPulse.exportHistory"
        },
        {
          "command": "fabricPulse.clearHistory"
        }
      ]
    },
    "configuration": {
      "title": "FabricPulse",
      "properties": {
        "fabricPulse.pollingInterval": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 3600,
          "description": "Auto-refresh interval in seconds (default: 60)"
        },
        "fabricPulse.retentionDays": {
          "type": "number",
          "default": 90,
          "minimum": 7,
          "maximum": 365,
          "description": "Days to retain pipeline run history (default: 90)"
        },
        "fabricPulse.dailyReportTime": {
          "type": "string",
          "default": "18:00",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$",
          "description": "Time to show daily summary notification (HH:MM, default: 18:00)"
        },
        "fabricPulse.batchSize": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 50,
          "description": "Number of pipelines fetched per batch when loading all workspaces (default: 5)"
        },
        "fabricPulse.batchDelayMs": {
          "type": "number",
          "default": 2500,
          "minimum": 500,
          "maximum": 30000,
          "description": "Delay in milliseconds between batches to avoid API rate limiting (default: 2500)"
        },
        "fabricPulse.batchThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 200,
          "description": "Minimum number of stale pipelines required to trigger batched loading (default: 10)"
        },
        "fabricPulse.blacklistedWorkspaces": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Workspaces to exclude from pipeline refresh. Accepts workspace IDs (GUIDs) or display names (case-insensitive)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "package": "node esbuild.js --production",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "node-fetch": "^2.7.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/node-fetch": "^2.6.11",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  }
}
